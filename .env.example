# Master API Key (required)
MASTER_API_KEY=your-master-api-key-change-this

# Database configuration
DATABASE_URL=sqlite+aiosqlite:///./data/proxy.db
# For production: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/llm_proxy

# Server configuration
HOST=127.0.0.1
# For remote access: HOST=0.0.0.0
PORT=8000

# Logging (use LOG_LEVEL=DEBUG to inspect stream response usage / cache fields: stream_sse_usage_chunk, stream_reconstructed_usage, stream_update_log)
LOG_LEVEL=INFO

# Storage (for request/response bodies)
STORAGE_TYPE=sqlite
# For production: STORAGE_TYPE=s3
# S3_BUCKET=llm-proxy-bodies
# S3_REGION=us-east-1
# S3_ACCESS_KEY=xxx
# S3_SECRET_KEY=xxx

# Semantic Cache (disabled by default)
CACHE_ENABLED=false
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=10000

# 连接预热（可选）：启动时对上游建连，减少首包 200–500ms 的 TCP+TLS
# PREWARM_URLS=https://coding.dashscope.aliyuncs.com/v1

# 对比测试 (test_proxy_vs_direct_stream.py)：直连 Bailian 用
# PROXY_URL=http://localhost:8000
# PROXY_KEY=sk-proxy-xxx   # OpenClawLocalTest 的 key
# BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BAILIAN_API_KEY=sk-xxx   # 或 DASHSCOPE_API_KEY
